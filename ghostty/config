# ╔══════════════════════════════════════╗
# ║         Ghostty Config               ║
# ║   🦐🥊 Claude Code Edition           ║
# ╚══════════════════════════════════════╝

# ── Font ──────────────────────────────────
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-feature = calt
font-feature = liga

# ── Theme ─────────────────────────────────
theme = Catppuccin Mocha

# ── Window ────────────────────────────────
confirm-close-surface = false
window-decoration = true
window-padding-x = 12
window-padding-y = 10
background-opacity = 0.92
background-blur = 20

# ── Font rendering ────────────────────────
font-thicken = true
font-thicken-strength = 64

# ── Cursor ────────────────────────────────
cursor-style = block
cursor-style-blink = true

# ── Shell Integration (Claude Code needs this) ──
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo,path

# ── Color / True Color (Claude Code TUI) ──
# Ghostty supports true color natively, no extra config needed.

# ── Clipboard ─────────────────────────────
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true

# ── Scrollback ────────────────────────────
scrollback-limit = 50000000

# ── Mouse ─────────────────────────────────
mouse-hide-while-typing = true
focus-follows-mouse = false

# ── Resize / Reflow ───────────────────────
# Don't reflow on resize - helps Claude Code TUI not break
resize-overlay = never

# ── Tabs & Splits (native, no tmux needed for basic use) ─
# ── Quick Terminal (Cmd+` from anywhere, needs Accessibility permission) ──
keybind = global:super+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-autohide = true

# ── Notifications ─────────────────────────
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s

# ── Key Bindings ──────────────────────────
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+t=new_window
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+]=next_tab
keybind = super+[=previous_tab
keybind = super+shift+f=toggle_fullscreen
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
# Go to tab by number
keybind = super+one=goto_tab:1
keybind = super+two=goto_tab:2
keybind = super+three=goto_tab:3
keybind = super+four=goto_tab:4
keybind = super+five=goto_tab:5
keybind = super+six=goto_tab:6

# ── Splits ────────────────────────────────────────
# Dim inactive splits so the active one stands out
unfocused-split-opacity = 0.85
unfocused-split-fill = 181825
split-divider-color = 45475a
# Navigate between splits
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom
# Resize splits
keybind = super+ctrl+left=resize_split:left,20
keybind = super+ctrl+right=resize_split:right,20
keybind = super+ctrl+up=resize_split:up,20
keybind = super+ctrl+down=resize_split:down,20
