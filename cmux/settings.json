{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux-settings.schema.json",
  "schemaVersion": 1,

  // Force dark mode + minimal mode (hides titlebar for cleaner look)
  "app": {
    "appearance": "dark",
    "appIcon": "dark",
    "minimalMode": true
  },

  // Sidebar blends with Catppuccin Mocha terminal background
  "sidebarAppearance": {
    "matchTerminalBackground": true,
    "tintColor": "#1e1e2e",
    "darkModeTintColor": "#1e1e2e",
    "tintOpacity": 0.85
  },

  // Catppuccin Mocha accent palette for workspace colors
  "workspaceColors": {
    "indicatorStyle": "wash",
    "selectionColor": "#313244",
    "notificationBadgeColor": "#f38ba8",
    "colors": {
      "Rosewater": "#f5e0dc",
      "Flamingo": "#f2cdcd",
      "Pink": "#f5c2e7",
      "Mauve": "#cba6f7",
      "Red": "#f38ba8",
      "Maroon": "#eba0ac",
      "Peach": "#fab387",
      "Yellow": "#f9e2af",
      "Green": "#a6e3a1",
      "Teal": "#94e2d5",
      "Sky": "#89dceb",
      "Sapphire": "#74c7ec",
      "Blue": "#89b4fa",
      "Lavender": "#b4befe"
    }
  },

  // Embedded browser matches dark theme
  "browser": {
    "theme": "dark"
  }
}
